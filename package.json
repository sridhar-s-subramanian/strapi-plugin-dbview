{
  "name": "@swamp-crocodile/strapi-plugin-dbview",
  "version": "0.1.1",
  "description": "Read-only database browser and SQL query runner for Strapi v5 admin panel",
  "type": "commonjs",
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ts:front": "tsc -p admin/tsconfig.json --noEmit",
    "test:ts:back": "tsc -p server/tsconfig.json --noEmit",
    "test:ts:spec": "tsc -p server/tsconfig.spec.json --noEmit && tsc -p admin/tsconfig.spec.json --noEmit",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "prepublishOnly": "npm run test && npm run build && npm run verify"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "strapi-server.js",
    "strapi-admin.js",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "node-sql-parser": "^5.4.0"
  },
  "devDependencies": {
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "@strapi/design-system": "^2.0.0",
    "@strapi/icons": "^2.0.0",
    "@strapi/sdk-plugin": "^5.2.0",
    "@strapi/strapi": "^5.0.0",
    "@strapi/typescript-utils": "^5.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "better-sqlite3": "^11.10.0",
    "codemirror": "^6.0.2",
    "knex": "^3.3.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-intl": "^6.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.0.0",
    "@strapi/icons": "^2.0.0",
    "@strapi/strapi": "^5.0.0",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "react-intl": "^6.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0 <=26.x.x",
    "npm": ">=6.0.0"
  },
  "strapi": {
    "kind": "plugin",
    "name": "strapi-dbview",
    "displayName": "DB View",
    "description": "Read-only database browser and SQL query runner for Strapi v5 admin panel"
  },
  "author": {
    "name": "R Sivasubramanian"
  },
  "license": "MIT",
  "keywords": [
    "strapi",
    "strapi-plugin",
    "database",
    "adminer",
    "dbview",
    "read-only",
    "sql",
    "query-runner"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sridhar-s-subramanian/strapi-plugin-dbview.git"
  }
}
